# Backend
PORT=4000
MONGODB_URI=mongodb://localhost:27017/vedaai
REDIS_URL=redis://localhost:6379

# Browser origins — required for production when frontend and backend are on different URLs (CORS + Socket.io).
# Local: Next.js dev server. Production: your deployed frontend URL (no trailing slash).
FRONTEND_URL=http://localhost:3000

# AI provider: gemini (recommended free) | groq | ollama | openai | anthropic
AI_PROVIDER=gemini

# --- Google Gemini — https://aistudio.google.com/apikey
# Same API key; use a model your Google AI project allows:
#   gemini-2.5-pro          — best quality (paid / higher quota tiers)
#   gemini-2.0-flash        — fast default on many plans
#   gemini-2.0-flash-lite   — lighter / fewer quota issues on free tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Groq (free tier, open models) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (100% local, no API key) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Paid (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Replace with a long random string in production (never commit the real value).
JWT_SECRET=changeme

# Frontend — exposed to the browser (NEXT_PUBLIC_*).
# Must be the API origin ONLY (no /api suffix); the client adds /api for REST calls.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Socket.io server URL (usually same origin as the API).
NEXT_PUBLIC_WS_URL=http://localhost:4000
